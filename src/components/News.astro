---
const announcements = [
  {
    title: 'Έναρξη Εγγραφών',
    excerpt: 'Οι εγγραφές για τη νέα σχολική χρονιά πραγματοποιούνται καθημερινά 5:30-8:30 μ.μ. Επικοινωνήστε μαζί μας για περισσότερες πληροφορίες.',
    date: 'Σεπτέμβριος',
    category: 'Ανακοίνωση',
    color: 'blue',
  },
  {
    title: 'Θερινή Προετοιμασία',
    excerpt: 'Τμήματα θερινής προετοιμασίας για μαθητές που θα φοιτήσουν στη Β\' και Γ\' Λυκείου. Εντατικά μαθήματα προετοιμασίας.',
    date: 'Ιούνιος',
    category: 'Πρόγραμμα',
    color: 'gold',
  },
  {
    title: 'Πανελλαδικές Εξετάσεις',
    excerpt: 'Με αποφασιστικότητα, με δύναμη, με την απόφαση. Καλή επιτυχία σε όλους τους μαθητές μας στις εξετάσεις!',
    date: 'Ιούνιος',
    category: 'Εξετάσεις',
    color: 'red',
  },
];
---

<section class="section news-section" id="news">
  <div class="container">
    <div class="section-header">
      <span class="section-label">Ενημέρωση</span>
      <h2 class="section-title">Νέα & Ανακοινώσεις</h2>
      <p class="section-subtitle">
        Μείνετε ενημερωμένοι για τις τελευταίες εξελίξεις και δραστηριότητες.
      </p>
    </div>

    <div class="news-grid">
      {announcements.map((item, i) => (
        <article class="news-card animate-on-scroll" data-delay={`${i * 0.1}s`}>
          <div class="news-header">
            <span class={`news-category ${item.color}`}>{item.category}</span>
            <span class="news-date">{item.date}</span>
          </div>
          <h3 class="news-title">{item.title}</h3>
          <p class="news-excerpt">{item.excerpt}</p>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .news-section {
    background: var(--surface);
  }

  .news-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
  }

  .news-card {
    background: white;
    border-radius: var(--radius);
    padding: 1.75rem;
    border: 1px solid rgba(0, 0, 0, 0.05);
    transition: all var(--transition);
    display: flex;
    flex-direction: column;
  }

  .news-card:hover {
    transform: translateY(-4px);
    box-shadow: var(--shadow-lg);
  }

  .news-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 1rem;
  }

  .news-category {
    font-family: 'Manrope', sans-serif;
    font-weight: 600;
    font-size: 0.75rem;
    padding: 0.3rem 0.8rem;
    border-radius: var(--radius-pill);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .news-category.blue {
    color: #2563EB;
    background: rgba(37, 99, 235, 0.08);
  }

  .news-category.gold {
    color: #D97706;
    background: rgba(245, 158, 11, 0.08);
  }

  .news-category.red {
    color: var(--accent);
    background: rgba(212, 42, 42, 0.08);
  }

  .news-date {
    font-size: 0.8rem;
    color: var(--text-muted);
  }

  .news-title {
    font-size: 1.15rem;
    margin-bottom: 0.75rem;
    color: var(--primary);
    line-height: 1.3;
  }

  .news-excerpt {
    font-size: 0.9rem;
    color: var(--text-muted);
    line-height: 1.6;
    flex: 1;
  }

  @media (max-width: 768px) {
    .news-grid {
      grid-template-columns: 1fr;
      max-width: 500px;
      margin: 0 auto;
    }
  }
</style>
