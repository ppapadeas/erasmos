<section class="section contact-section" id="contact">
  <div class="container">
    <div class="section-header">
      <span class="section-label">Επικοινωνία</span>
      <h2 class="section-title">Επικοινωνήστε μαζί μας</h2>
      <p class="section-subtitle">
        Είμαστε εδώ για να απαντήσουμε σε κάθε ερώτησή σας.
      </p>
    </div>

    <div class="contact-grid">
      <!-- Contact Form -->
      <div class="contact-form-wrap animate-on-scroll">
        <form class="contact-form" action="https://formspree.io/f/xpznqwrl" method="POST">
          <div class="form-group">
            <label for="name">Ονοματεπώνυμο</label>
            <input type="text" id="name" name="name" required placeholder="Το όνομά σας" />
          </div>
          <div class="form-row">
            <div class="form-group">
              <label for="email">Email</label>
              <input type="email" id="email" name="email" required placeholder="email@example.com" />
            </div>
            <div class="form-group">
              <label for="phone">Τηλέφωνο</label>
              <input type="tel" id="phone" name="phone" placeholder="210 XXXXXXX" />
            </div>
          </div>
          <div class="form-group">
            <label for="message">Μήνυμα</label>
            <textarea id="message" name="message" rows="5" required placeholder="Γράψτε το μήνυμά σας..."></textarea>
          </div>
          <button type="submit" class="btn btn-primary submit-btn">
            Αποστολή
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="22" y1="2" x2="11" y2="13"/><polygon points="22 2 15 22 11 13 2 9 22 2"/></svg>
          </button>
        </form>
      </div>

      <!-- Contact Info -->
      <div class="contact-info animate-on-scroll slide-right">
        <div class="info-cards">
          <div class="info-card">
            <div class="info-icon">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
            </div>
            <div>
              <h4>Διεύθυνση</h4>
              <p>Θεμιστοκλή Σοφούλη 61<br/>Νέα Φιλαδέλφεια, Αθήνα</p>
            </div>
          </div>

          <div class="info-card">
            <div class="info-icon">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
            </div>
            <div>
              <h4>Τηλέφωνα</h4>
              <p>
                <a href="tel:+302102582744">210 258 2744</a><br/>
                <a href="tel:+306977515950">697 751 5950</a>
              </p>
            </div>
          </div>

          <div class="info-card">
            <div class="info-icon">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
            </div>
            <div>
              <h4>Email</h4>
              <p><a href="mailto:erasmosfront@yahoo.gr">erasmosfront@yahoo.gr</a></p>
            </div>
          </div>

          <div class="info-card">
            <div class="info-icon">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="2" y1="12" x2="22" y2="12"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></svg>
            </div>
            <div>
              <h4>eClass</h4>
              <p><a href="https://eclass.erasmosfront.gr" target="_blank" rel="noopener">eclass.erasmosfront.gr</a></p>
            </div>
          </div>
        </div>

        <div class="social-links">
          <a href="https://www.facebook.com/erasmosfront" target="_blank" rel="noopener noreferrer" aria-label="Facebook" class="social-link">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
          </a>
          <a href="https://www.instagram.com/erasmosfront" target="_blank" rel="noopener noreferrer" aria-label="Instagram" class="social-link">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/></svg>
          </a>
        </div>

        <!-- Google Map -->
        <div class="map-container">
          <iframe
            src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3143.1!2d23.738!3d38.035!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x14a1a2a0a0a0a0a0%3A0x0!2zIM6YzrXOvM65z4PPhM6_zrrOu86uIM6jzr_Phs6_z43Ou863IDYxLCDOnc6tzrEgzqbOuc67zrHOtM6tzrvPhs61zrnOsQ!5e0!3m2!1sel!2sgr!4v1600000000000"
            width="100%"
            height="200"
            style="border:0; border-radius: var(--radius);"
            allowfullscreen=""
            loading="lazy"
            referrerpolicy="no-referrer-when-downgrade"
            title="Erasmos Frontistirio Location"
          ></iframe>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .contact-section {
    background: white;
  }

  .contact-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 3rem;
    align-items: start;
  }

  /* Form */
  .contact-form {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  .form-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.25rem;
  }

  .form-group {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }

  .form-group label {
    font-family: 'Manrope', sans-serif;
    font-weight: 600;
    font-size: 0.85rem;
    color: var(--text-primary);
  }

  .form-group input,
  .form-group textarea {
    font-family: 'Inter', sans-serif;
    font-size: 0.95rem;
    padding: 0.8rem 1rem;
    border: 2px solid rgba(0, 0, 0, 0.08);
    border-radius: var(--radius);
    background: var(--surface);
    color: var(--text-primary);
    transition: all var(--transition);
    outline: none;
  }

  .form-group input:focus,
  .form-group textarea:focus {
    border-color: var(--primary-lighter);
    box-shadow: 0 0 0 3px rgba(37, 99, 235, 0.1);
  }

  .form-group textarea {
    resize: vertical;
    min-height: 120px;
  }

  .submit-btn {
    align-self: flex-start;
    padding: 0.9rem 2.5rem;
  }

  /* Info Cards */
  .info-cards {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    margin-bottom: 1.5rem;
  }

  .info-card {
    display: flex;
    align-items: flex-start;
    gap: 1rem;
    padding: 1rem;
    border-radius: var(--radius);
    transition: background var(--transition);
  }

  .info-card:hover {
    background: var(--surface);
  }

  .info-icon {
    width: 44px;
    height: 44px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(10, 37, 64, 0.06);
    border-radius: 10px;
    color: var(--primary);
    flex-shrink: 0;
  }

  .info-card h4 {
    font-family: 'Manrope', sans-serif;
    font-size: 0.9rem;
    font-weight: 700;
    color: var(--primary);
    margin-bottom: 0.25rem;
  }

  .info-card p {
    font-size: 0.9rem;
    color: var(--text-muted);
    line-height: 1.5;
  }

  .info-card a {
    color: var(--primary-lighter);
    transition: color var(--transition);
  }

  .info-card a:hover {
    color: var(--primary);
  }

  /* Social */
  .social-links {
    display: flex;
    gap: 0.75rem;
    margin-bottom: 1.5rem;
    padding-left: 1rem;
  }

  .social-link {
    width: 42px;
    height: 42px;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 10px;
    background: rgba(10, 37, 64, 0.06);
    color: var(--primary);
    transition: all var(--transition);
  }

  .social-link:hover {
    background: var(--primary);
    color: white;
    transform: translateY(-2px);
  }

  /* Map */
  .map-container {
    border-radius: var(--radius);
    overflow: hidden;
    box-shadow: var(--shadow-sm);
  }

  @media (max-width: 768px) {
    .contact-grid {
      grid-template-columns: 1fr;
      gap: 2rem;
    }
    .form-row {
      grid-template-columns: 1fr;
    }
  }
</style>
