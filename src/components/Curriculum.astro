---
const gymnasium = {
  'Α\' Γυμνασίου': {
    hours: 4,
    subjects: [
      { name: 'Νεοελληνική Γλώσσα', hours: 1 },
      { name: 'Μαθηματικά', hours: 2 },
      { name: 'Αρχαία Ελληνικά', hours: 1 },
    ],
  },
  'Β\' Γυμνασίου': {
    hours: 5,
    subjects: [
      { name: 'Νεοελληνική Γλώσσα', hours: 1 },
      { name: 'Μαθηματικά', hours: 2 },
      { name: 'Φυσική', hours: 1 },
      { name: 'Αρχαία Ελληνικά', hours: 1 },
    ],
  },
  'Γ\' Γυμνασίου': {
    hours: 5,
    subjects: [
      { name: 'Νεοελληνική Γλώσσα', hours: 1 },
      { name: 'Μαθηματικά', hours: 2 },
      { name: 'Φυσική', hours: 1 },
      { name: 'Αρχαία Ελληνικά', hours: 1 },
    ],
  },
};

const lyceum = {
  'Α\' Λυκείου': {
    hours: 10,
    subjects: [
      { name: 'Νεοελληνική Γλώσσα', hours: 1 },
      { name: 'Άλγεβρα', hours: 3 },
      { name: 'Γεωμετρία', hours: 1 },
      { name: 'Φυσική', hours: 3 },
      { name: 'Χημεία', hours: 1 },
      { name: 'Αρχαία Ελληνικά', hours: 1 },
    ],
  },
  'Β\'-Γ\' Ανθρωπιστικές': {
    hours: null,
    subjects: [
      { name: 'Νεοελληνική Γλώσσα & Λογοτεχνία', hours: null },
      { name: 'Αρχαία Ελληνικά', hours: null },
      { name: 'Ιστορία', hours: null },
      { name: 'Λατινικά', hours: null },
    ],
  },
  'Β\'-Γ\' Θετικές': {
    hours: null,
    subjects: [
      { name: 'Νεοελληνική Γλώσσα & Λογοτεχνία', hours: null },
      { name: 'Φυσική', hours: null },
      { name: 'Χημεία', hours: null },
      { name: 'Μαθηματικά', hours: null },
    ],
  },
  'Β\'-Γ\' Υγείας': {
    hours: null,
    subjects: [
      { name: 'Νεοελληνική Γλώσσα & Λογοτεχνία', hours: null },
      { name: 'Φυσική', hours: null },
      { name: 'Χημεία', hours: null },
      { name: 'Βιολογία', hours: null },
    ],
  },
  'Β\'-Γ\' Οικονομίας & Πληροφορικής': {
    hours: null,
    subjects: [
      { name: 'Νεοελληνική Γλώσσα & Λογοτεχνία', hours: null },
      { name: 'Μαθηματικά', hours: null },
      { name: 'Πληροφορική', hours: null },
      { name: 'Οικονομία', hours: null },
    ],
  },
};
---

<section class="section curriculum-section" id="curriculum">
  <div class="container">
    <div class="section-header">
      <span class="section-label">Πρόγραμμα Σπουδών</span>
      <h2 class="section-title">Μαθήματα & Ώρες</h2>
      <p class="section-subtitle">
        Ευέλικτο πρόγραμμα σπουδών δομημένο ώστε να καλύπτει πλήρως τις ανάγκες κάθε μαθητή.
      </p>
    </div>

    <!-- Main Tabs -->
    <div class="tab-nav" id="main-tabs">
      <button class="tab-btn active" data-tab="gymnasium">Γυμνάσιο</button>
      <button class="tab-btn" data-tab="lyceum">Λύκειο</button>
    </div>

    <!-- Gymnasium Content -->
    <div class="tab-content active" id="gymnasium">
      <div class="sub-tabs">
        {Object.keys(gymnasium).map((grade, i) => (
          <button class={`sub-tab-btn ${i === 0 ? 'active' : ''}`} data-subtab={`gym-${i}`}>
            {grade}
          </button>
        ))}
      </div>
      {Object.entries(gymnasium).map(([grade, data], i) => (
        <div class={`sub-content ${i === 0 ? 'active' : ''}`} id={`gym-${i}`}>
          <div class="subject-grid animate-on-scroll">
            {data.subjects.map((subject) => (
              <div class="subject-card">
                <span class="subject-name">{subject.name}</span>
                <span class="subject-hours">{subject.hours} ώρα{subject.hours > 1 ? 'ες' : ''}/εβδ.</span>
              </div>
            ))}
            <div class="subject-total">
              <span>Σύνολο</span>
              <span class="total-hours">{data.hours} ώρες/εβδομάδα</span>
            </div>
          </div>
        </div>
      ))}
    </div>

    <!-- Lyceum Content -->
    <div class="tab-content" id="lyceum">
      <div class="sub-tabs">
        {Object.keys(lyceum).map((grade, i) => (
          <button class={`sub-tab-btn ${i === 0 ? 'active' : ''}`} data-subtab={`lyc-${i}`}>
            {grade}
          </button>
        ))}
      </div>
      {Object.entries(lyceum).map(([grade, data], i) => (
        <div class={`sub-content ${i === 0 ? 'active' : ''}`} id={`lyc-${i}`}>
          <div class="subject-grid animate-on-scroll">
            {data.subjects.map((subject) => (
              <div class="subject-card">
                <span class="subject-name">{subject.name}</span>
                {subject.hours && (
                  <span class="subject-hours">{subject.hours} ώρα{subject.hours > 1 ? 'ες' : ''}/εβδ.</span>
                )}
              </div>
            ))}
            {data.hours && (
              <div class="subject-total">
                <span>Σύνολο</span>
                <span class="total-hours">{data.hours} ώρες/εβδομάδα</span>
              </div>
            )}
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<script>
  // Main tabs
  document.querySelectorAll('.tab-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      document.querySelectorAll('.tab-btn').forEach(b => b.classList.remove('active'));
      document.querySelectorAll('.tab-content').forEach(c => c.classList.remove('active'));
      btn.classList.add('active');
      const tabId = (btn as HTMLElement).dataset.tab!;
      document.getElementById(tabId)!.classList.add('active');
    });
  });

  // Sub tabs
  document.querySelectorAll('.sub-tab-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      const parent = btn.closest('.tab-content')!;
      parent.querySelectorAll('.sub-tab-btn').forEach(b => b.classList.remove('active'));
      parent.querySelectorAll('.sub-content').forEach(c => c.classList.remove('active'));
      btn.classList.add('active');
      const subId = (btn as HTMLElement).dataset.subtab!;
      parent.querySelector(`#${subId}`)!.classList.add('active');
    });
  });
</script>

<style>
  .curriculum-section {
    background: linear-gradient(180deg, var(--surface) 0%, white 100%);
  }

  .tab-nav {
    display: flex;
    justify-content: center;
    gap: 0.5rem;
    margin-bottom: 2rem;
  }

  .tab-btn {
    font-family: 'Manrope', sans-serif;
    font-weight: 700;
    font-size: 1rem;
    padding: 0.75rem 2rem;
    border-radius: var(--radius-pill);
    color: var(--text-muted);
    background: transparent;
    border: 2px solid transparent;
    transition: all var(--transition);
  }

  .tab-btn.active {
    color: var(--primary);
    background: white;
    border-color: var(--primary);
    box-shadow: var(--shadow-sm);
  }

  .tab-btn:hover:not(.active) {
    color: var(--primary);
    background: rgba(10, 37, 64, 0.04);
  }

  .tab-content {
    display: none;
    max-width: 700px;
    margin: 0 auto;
  }

  .tab-content.active {
    display: block;
    animation: fadeIn 0.3s ease;
  }

  .sub-tabs {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 0.5rem;
    margin-bottom: 1.5rem;
  }

  .sub-tab-btn {
    font-family: 'Manrope', sans-serif;
    font-weight: 600;
    font-size: 0.85rem;
    padding: 0.5rem 1.25rem;
    border-radius: var(--radius-pill);
    color: var(--text-muted);
    transition: all var(--transition);
  }

  .sub-tab-btn.active {
    color: white;
    background: var(--primary);
  }

  .sub-tab-btn:hover:not(.active) {
    color: var(--primary);
    background: rgba(10, 37, 64, 0.06);
  }

  .sub-content {
    display: none;
  }

  .sub-content.active {
    display: block;
    animation: fadeIn 0.3s ease;
  }

  .subject-grid {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .subject-card {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 1rem 1.5rem;
    background: white;
    border-radius: var(--radius);
    box-shadow: var(--shadow-sm);
    border: 1px solid rgba(0, 0, 0, 0.04);
    transition: all var(--transition);
  }

  .subject-card:hover {
    box-shadow: var(--shadow-md);
    transform: translateX(4px);
  }

  .subject-name {
    font-weight: 500;
    color: var(--text-primary);
  }

  .subject-hours {
    font-family: 'Manrope', sans-serif;
    font-weight: 700;
    font-size: 0.85rem;
    color: var(--primary-lighter);
    background: rgba(37, 99, 235, 0.08);
    padding: 0.3rem 0.8rem;
    border-radius: var(--radius-pill);
    white-space: nowrap;
  }

  .subject-total {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 1rem 1.5rem;
    background: var(--primary);
    color: white;
    border-radius: var(--radius);
    font-family: 'Manrope', sans-serif;
    font-weight: 700;
  }

  .total-hours {
    font-size: 1.1rem;
  }

  @media (max-width: 768px) {
    .tab-btn {
      font-size: 0.9rem;
      padding: 0.6rem 1.5rem;
    }
    .sub-tab-btn {
      font-size: 0.75rem;
      padding: 0.4rem 0.8rem;
    }
    .subject-card {
      padding: 0.75rem 1rem;
      flex-direction: column;
      align-items: flex-start;
      gap: 0.5rem;
    }
  }
</style>
