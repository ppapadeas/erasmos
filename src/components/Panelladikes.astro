---
const resources = [
  {
    icon: `<svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/><polyline points="10 9 9 9 8 9"/></svg>`,
    title: 'Θέματα Εξετάσεων',
    description: 'Αρχείο θεμάτων πανελλαδικών εξετάσεων προηγούμενων ετών για εξάσκηση.',
    href: 'http://www.iep.edu.gr/el/anazitisi-thematon',
    linkText: 'Δείτε τα θέματα',
  },
  {
    icon: `<svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M18 20V10"/><path d="M12 20V4"/><path d="M6 20v-6"/></svg>`,
    title: 'Βάσεις Τμημάτων',
    description: 'Βάσεις εισαγωγής τμημάτων τριτοβάθμιας εκπαίδευσης ανά χρονιά.',
    href: 'https://www.it.minedu.gov.gr',
    linkText: 'Δείτε τις βάσεις',
  },
  {
    icon: `<svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="4" y="4" width="16" height="16" rx="2"/><path d="M4 10h16"/><path d="M10 4v16"/></svg>`,
    title: 'Υπολογισμός Μορίων',
    description: 'Υπολογίστε τα μόριά σας μέσω της επίσημης εφαρμογής του Υπουργείου Παιδείας.',
    href: 'https://markcalc.it.minedu.gov.gr/',
    linkText: 'Υπολογίστε μόρια',
  },
];
---

<section class="section" id="exams">
  <div class="container">
    <div class="section-header">
      <span class="section-label">Πανελλαδικές Εξετάσεις</span>
      <h2 class="section-title">Χρήσιμα Εργαλεία</h2>
      <p class="section-subtitle">
        Εργαλεία και πηγές για την προετοιμασία σας στις πανελλαδικές εξετάσεις.
      </p>
    </div>

    <div class="resources-grid">
      {resources.map((r, i) => (
        <a href={r.href} target="_blank" rel="noopener noreferrer" class="resource-card animate-on-scroll scale-in" data-delay={`${i * 0.1}s`}>
          <div class="resource-icon" set:html={r.icon} />
          <h3 class="resource-title">{r.title}</h3>
          <p class="resource-desc">{r.description}</p>
          <span class="resource-link">
            {r.linkText}
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
          </span>
        </a>
      ))}
    </div>
  </div>
</section>

<style>
  .resources-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
  }

  .resource-card {
    background: white;
    border-radius: var(--radius);
    padding: 2rem;
    text-align: center;
    border: 1px solid rgba(0, 0, 0, 0.05);
    transition: all var(--transition);
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .resource-card:hover {
    transform: translateY(-6px);
    box-shadow: var(--shadow-lg);
    border-color: rgba(37, 99, 235, 0.15);
  }

  .resource-icon {
    width: 64px;
    height: 64px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: linear-gradient(135deg, rgba(10, 37, 64, 0.06), rgba(37, 99, 235, 0.08));
    border-radius: 16px;
    color: var(--primary);
    margin-bottom: 1.25rem;
  }

  .resource-title {
    font-size: 1.1rem;
    margin-bottom: 0.75rem;
    color: var(--primary);
  }

  .resource-desc {
    font-size: 0.9rem;
    color: var(--text-muted);
    line-height: 1.6;
    margin-bottom: 1.25rem;
    flex: 1;
  }

  .resource-link {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    font-family: 'Manrope', sans-serif;
    font-weight: 600;
    font-size: 0.9rem;
    color: var(--primary-lighter);
    transition: gap var(--transition);
  }

  .resource-card:hover .resource-link {
    gap: 0.7rem;
  }

  @media (max-width: 768px) {
    .resources-grid {
      grid-template-columns: 1fr;
      max-width: 400px;
      margin: 0 auto;
    }
  }
</style>
