---
const milestones = [
  {
    year: '1995',
    title: 'Ίδρυση',
    description: 'Το Φροντιστήριο Erasmos ξεκινά τη λειτουργία του στη Θεμιστοκλή Σοφούλη 21, Νέα Φιλαδέλφεια. Γρήγορα γίνεται μια από τις πρωταρχικές εκπαιδευτικές επιλογές στην περιοχή.',
  },
  {
    year: '2004',
    title: 'Νέα Στέγη',
    description: 'Μεταφορά σε ειδικά σχεδιασμένο, ιδιόκτητο κτίριο στη Θεμιστοκλή Σοφούλη 61, κατασκευασμένο για τις σύγχρονες ανάγκες της δευτεροβάθμιας εκπαίδευσης.',
  },
  {
    year: 'Σήμερα',
    title: 'Συνεχής Εξέλιξη',
    description: 'Εκατοντάδες μαθητές έχουν πετύχει τους στόχους τους για εισαγωγή στην τριτοβάθμια εκπαίδευση μέσα από αφοσίωση, σκληρή δουλειά και αγάπη για τη μάθηση.',
  },
];
---

<section class="history-section">
  <div class="container">
    <div class="section-header">
      <span class="section-label">Η Ιστορία μας</span>
      <h2 class="section-title">Η Πορεία μας</h2>
      <p class="section-subtitle">Από το 1995, χτίζουμε μέλλον μαζί με τους μαθητές μας.</p>
    </div>

    <div class="timeline">
      <div class="timeline-line"></div>
      {milestones.map((m, i) => (
        <div class={`timeline-item ${i % 2 === 0 ? 'left' : 'right'} animate-on-scroll`} data-delay={`${i * 0.15}s`}>
          <div class="timeline-dot"></div>
          <div class="timeline-card">
            <span class="timeline-year">{m.year}</span>
            <h3 class="timeline-title">{m.title}</h3>
            <p class="timeline-desc">{m.description}</p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .history-section {
    padding: 5rem 0;
    background: var(--surface);
  }

  .timeline {
    position: relative;
    max-width: 800px;
    margin: 0 auto;
    padding: 2rem 0;
  }

  .timeline-line {
    position: absolute;
    left: 50%;
    top: 0;
    bottom: 0;
    width: 2px;
    background: linear-gradient(180deg, var(--primary) 0%, var(--primary-light) 100%);
    transform: translateX(-50%);
    opacity: 0.2;
  }

  .timeline-item {
    position: relative;
    width: 50%;
    padding: 1rem 2.5rem;
    margin-bottom: 2rem;
  }

  .timeline-item.left {
    left: 0;
    text-align: right;
    padding-right: 3rem;
    padding-left: 0;
  }

  .timeline-item.right {
    left: 50%;
    text-align: left;
    padding-left: 3rem;
    padding-right: 0;
  }

  .timeline-dot {
    position: absolute;
    width: 16px;
    height: 16px;
    background: var(--primary);
    border-radius: 50%;
    border: 3px solid var(--surface);
    box-shadow: 0 0 0 3px var(--primary);
    z-index: 1;
  }

  .timeline-item.left .timeline-dot {
    right: -8px;
  }

  .timeline-item.right .timeline-dot {
    left: -8px;
  }

  .timeline-card {
    background: white;
    padding: 1.75rem;
    border-radius: var(--radius);
    box-shadow: var(--shadow-sm);
    border: 1px solid rgba(0, 0, 0, 0.04);
    transition: all var(--transition);
  }

  .timeline-card:hover {
    box-shadow: var(--shadow-md);
    transform: translateY(-2px);
  }

  .timeline-year {
    font-family: 'Manrope', sans-serif;
    font-weight: 800;
    font-size: 1.5rem;
    color: var(--primary-lighter);
    display: block;
    margin-bottom: 0.5rem;
  }

  .timeline-title {
    font-size: 1.15rem;
    margin-bottom: 0.5rem;
    color: var(--primary);
  }

  .timeline-desc {
    font-size: 0.9rem;
    line-height: 1.6;
    color: var(--text-muted);
  }

  @media (max-width: 768px) {
    .timeline-line {
      left: 20px;
    }
    .timeline-item,
    .timeline-item.left,
    .timeline-item.right {
      width: 100%;
      left: 0;
      text-align: left;
      padding-left: 3.5rem;
      padding-right: 0;
    }
    .timeline-item.left .timeline-dot,
    .timeline-item.right .timeline-dot {
      left: 12px;
      right: auto;
    }
  }
</style>
