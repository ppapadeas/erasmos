---
const quotes = [
  {
    text: 'Education is the most powerful weapon which you can use to change the world.',
    author: 'Nelson Mandela',
    textEl: 'Η εκπαίδευση είναι το πιο ισχυρό όπλο που μπορείτε να χρησιμοποιήσετε για να αλλάξετε τον κόσμο.',
  },
  {
    text: '',
    author: 'Πλάτων',
    textEl: 'Η παιδεία είναι δύναμη που γιατρεύει την ψυχή.',
  },
  {
    text: '',
    author: 'Albert Einstein',
    textEl: 'Όποιος δεν έκανε ποτέ λάθος, δεν δοκίμασε ποτέ κάτι καινούργιο.',
  },
  {
    text: '',
    author: 'Πλούταρχος',
    textEl: 'Το μυαλό δεν είναι ένα δοχείο που πρέπει να γεμίσει, αλλά μια φωτιά που πρέπει να ανάψει.',
  },
];
---

<section class="quotes-section">
  <div class="container">
    <div class="quote-container" id="quote-carousel">
      <div class="quote-mark">&ldquo;</div>
      {quotes.map((q, i) => (
        <div class={`quote-slide ${i === 0 ? 'active' : ''}`} data-index={i}>
          <blockquote class="quote-text">{q.textEl}</blockquote>
          <cite class="quote-author">&mdash; {q.author}</cite>
        </div>
      ))}
      <div class="quote-dots">
        {quotes.map((_, i) => (
          <button class={`quote-dot ${i === 0 ? 'active' : ''}`} data-dot={i} aria-label={`Quote ${i + 1}`}></button>
        ))}
      </div>
    </div>
  </div>
</section>

<script>
  const slides = document.querySelectorAll('.quote-slide');
  const dots = document.querySelectorAll('.quote-dot');
  let current = 0;
  let interval: ReturnType<typeof setInterval>;

  function showSlide(index: number) {
    slides.forEach(s => s.classList.remove('active'));
    dots.forEach(d => d.classList.remove('active'));
    slides[index].classList.add('active');
    dots[index].classList.add('active');
    current = index;
  }

  function next() {
    showSlide((current + 1) % slides.length);
  }

  function startAutoplay() {
    interval = setInterval(next, 6000);
  }

  dots.forEach(dot => {
    dot.addEventListener('click', () => {
      clearInterval(interval);
      showSlide(parseInt((dot as HTMLElement).dataset.dot!));
      startAutoplay();
    });
  });

  startAutoplay();
</script>

<style>
  .quotes-section {
    padding: 6rem 0;
    background: linear-gradient(135deg, var(--surface-dark) 0%, #1a1a2e 100%);
    position: relative;
    overflow: hidden;
  }

  .quotes-section::before {
    content: '';
    position: absolute;
    inset: 0;
    background: radial-gradient(ellipse at 70% 30%, rgba(37, 99, 235, 0.1) 0%, transparent 60%);
  }

  .quote-container {
    position: relative;
    max-width: 750px;
    margin: 0 auto;
    text-align: center;
    min-height: 250px;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
  }

  .quote-mark {
    font-family: Georgia, serif;
    font-size: 6rem;
    color: rgba(255, 255, 255, 0.08);
    line-height: 1;
    position: absolute;
    top: -1.5rem;
    left: 50%;
    transform: translateX(-50%);
  }

  .quote-slide {
    position: absolute;
    inset: 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    opacity: 0;
    transform: translateY(10px);
    transition: all 0.6s ease;
    pointer-events: none;
    padding: 2rem 1rem;
  }

  .quote-slide.active {
    opacity: 1;
    transform: translateY(0);
    pointer-events: all;
  }

  .quote-text {
    font-family: 'Manrope', sans-serif;
    font-size: clamp(1.1rem, 3vw, 1.5rem);
    font-weight: 600;
    color: rgba(255, 255, 255, 0.9);
    line-height: 1.6;
    font-style: italic;
    margin-bottom: 1.5rem;
  }

  .quote-author {
    font-family: 'Manrope', sans-serif;
    font-size: 0.95rem;
    font-weight: 600;
    color: var(--gold);
    font-style: normal;
  }

  .quote-dots {
    position: absolute;
    bottom: 0;
    display: flex;
    gap: 0.5rem;
    z-index: 2;
  }

  .quote-dot {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    background: rgba(255, 255, 255, 0.2);
    border: none;
    cursor: pointer;
    transition: all var(--transition);
    padding: 0;
  }

  .quote-dot.active {
    background: var(--gold);
    transform: scale(1.3);
  }

  .quote-dot:hover {
    background: rgba(255, 255, 255, 0.4);
  }
</style>
